{
  "name": "cdyun/thinkphp-jwt",
  "description": "Thinkphp JWT令牌，Json web token 是为了在网络应用环境间传递声明而执行的一种基于JSON的开放标准（(RFC 7519)。该token被设计为紧凑且安全的，特别适用于分布式站点的单点登录（SSO）场景。",
  "license": "MIT",
  "keywords": [
    "php",
    "jwt",
    "cdyun"
  ],
  "authors": [
    {
      "name": "cdyun",
      "email": "121625706@qq.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.0",
    "firebase/php-jwt": "^6.11||^7.0"
  },
  "autoload": {
    "psr-4": {
      "Cdyun\\ThinkphpJwt\\": "src/"
    }
  },
  "extra": {
      "think": {
          "config":{
              "jwt": "src/config/config.php"
          }            
      }
  }
}